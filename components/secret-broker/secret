#!/usr/bin/env python3
"""ai-os secret broker — the local capability that lets your AI-OS *use* a
credential without ever seeing it.

Design (see cvp1/ai-os-pro, native component #1):
  - A skill NEVER names a value, only a handle:  secret://<name>
  - The value lives in your OS keyring (macOS Keychain / Linux Secret Service).
  - This broker reads it INTERNALLY, performs the authed action, and returns
    ONLY the outcome. There is deliberately NO verb that prints a stored value.

Honest limit: this keeps the secret out of the model's reach and out of your
logs. It is NOT a sandbox — a process running as you can still reach the keyring.
We never claim "impossible to exfiltrate", only "the AI never handles the value".

stdlib only. Zero pip dependencies. Python 3.8+.
"""
from __future__ import annotations

import argparse
import json
import os
import re
import subprocess
import sys
import urllib.request
from datetime import datetime, timezone

SERVICE = "ai-os"
HOME = os.path.expanduser("~")
AIOS_DIR = os.path.join(HOME, "ai-os")
AUDIT_PATH = os.path.join(AIOS_DIR, ".secrets-audit.jsonl")
INDEX_PATH = os.path.join(AIOS_DIR, ".secret-handles")  # handle NAMES only, never values

_NAME_RE = re.compile(r"^[A-Za-z0-9._-]+$")


# --------------------------------------------------------------------------- #
# errors
# --------------------------------------------------------------------------- #
class BrokerError(Exception):
    """A user-facing error whose message is guaranteed secret-free."""


def _die(msg: str, code: int = 1) -> "int":
    print(f"secret: {msg}", file=sys.stderr)
    return code


# --------------------------------------------------------------------------- #
# handle parsing
# --------------------------------------------------------------------------- #
def parse_handle(handle: str) -> str:
    """secret://<name> -> <name>, validated. Never returns a value."""
    if not handle.startswith("secret://"):
        raise BrokerError(f"not a handle (expected secret://<name>): {handle!r}")
    name = handle[len("secret://"):]
    if not _NAME_RE.match(name):
        raise BrokerError(
            f"invalid handle name {name!r} (allowed: letters, digits, . _ -)"
        )
    return name


# --------------------------------------------------------------------------- #
# keyring backend — the ONLY place a raw value is touched
# these three functions are deliberately small + stubbable for tests
# --------------------------------------------------------------------------- #
def _store_dir() -> "str|None":
    """Directory for the file backend (used only when no OS keyring is present).
    Explicit via $AIOS_SECRET_STORE_DIR; else ~/.key/aios if a ~/.key vault
    exists (e.g. an fscrypt-encrypted vault). At-rest protection is THAT
    directory's — not something this broker provides."""
    d = os.environ.get("AIOS_SECRET_STORE_DIR")
    if d:
        return os.path.expanduser(d)
    vault = os.path.join(HOME, ".key")
    if os.path.isdir(vault):
        return os.path.join(vault, "aios")
    return None


def _backend() -> str:
    if sys.platform == "darwin" and _which("security"):
        return "macos"
    if sys.platform.startswith("linux") and _which("secret-tool"):
        return "linux"
    if _store_dir() is not None:
        return "file"
    return "none"


def _vault_locked(store_dir: "str|None") -> bool:
    """True if the file store sits in an encrypted vault that is currently LOCKED
    (e.g. an fscrypt ~/.key just after reboot). Signalled by a `.vault_unlocked`
    plaintext canary at the vault root — present iff unlocked. Set
    $AIOS_SECRET_VAULT_CANARY to point at your own canary; otherwise the vault
    root is taken as the store dir's parent (so ~/.key/aios -> ~/.key). Returns
    False for a plain (unencrypted) dir so a genuine 'not stored' reads normally."""
    env = os.environ.get("AIOS_SECRET_VAULT_CANARY")
    if env:
        return not os.path.exists(env)
    # Auto lock-detection applies ONLY to the auto-derived ~/.key/aios vault (the
    # fscrypt convention). An explicit $AIOS_SECRET_STORE_DIR opts out unless it
    # also sets $AIOS_SECRET_VAULT_CANARY (handled above).
    if os.environ.get("AIOS_SECRET_STORE_DIR") or not store_dir:
        return False
    root = os.path.dirname(os.path.normpath(store_dir))   # ~/.key for ~/.key/aios
    if not os.path.isdir(root) or os.path.exists(os.path.join(root, ".vault_unlocked")):
        return False
    return True  # a ~/.key vault with no .vault_unlocked canary is locked


def _ensure_unlocked() -> None:
    d = _store_dir()
    if _vault_locked(d):
        root = os.path.dirname(os.path.normpath(d)) if d else "?"
        hint = os.environ.get("AIOS_SECRET_UNLOCK_HINT",
                              "unlock your encrypted secret store and retry")
        raise BrokerError(f"\U0001f512 secret store is locked ({root}). {hint}")


def _which(exe: str) -> "str|None":
    for d in os.environ.get("PATH", "").split(os.pathsep):
        p = os.path.join(d, exe)
        if os.path.isfile(p) and os.access(p, os.X_OK):
            return p
    return None


def _no_keyring() -> BrokerError:
    return BrokerError(
        "no secret store available. Preferred: an OS keyring (macOS Keychain, or "
        "Linux gnome-keyring + libsecret-tools for 'secret-tool'). Headless "
        "alternative: set $AIOS_SECRET_STORE_DIR to an ENCRYPTED directory (or "
        "create a ~/.key vault, e.g. fscrypt) and the broker will use a file "
        "store there. Nothing was stored."
    )


def _kr_store(name: str, value: str) -> None:
    b = _backend()
    if b == "macos":
        # NOTE: `security` takes the value as an argv (-w); briefly visible to a
        # local `ps` on this machine only. The GUI path (Keychain Access) avoids
        # even that and is the documented primary store method (README §store).
        _run(["security", "add-generic-password", "-U",
              "-s", SERVICE, "-a", name, "-w", value])
    elif b == "linux":
        # secret-tool reads the value from STDIN — never an argv, no ps exposure.
        _run(["secret-tool", "store", "--label=ai-os",
              "service", SERVICE, "account", name], stdin=value)
    elif b == "file":
        _ensure_unlocked()
        d = _store_dir()
        os.makedirs(d, exist_ok=True)
        os.chmod(d, 0o700)
        path = os.path.join(d, name)
        tmp = path + ".tmp"
        fd = os.open(tmp, os.O_WRONLY | os.O_CREAT | os.O_TRUNC, 0o600)
        with os.fdopen(fd, "w") as f:
            f.write(value)
        os.replace(tmp, path)
    else:
        raise _no_keyring()


def _kr_get(name: str) -> str:
    b = _backend()
    if b == "macos":
        out = _run(["security", "find-generic-password",
                    "-s", SERVICE, "-a", name, "-w"], capture=True)
    elif b == "linux":
        out = _run(["secret-tool", "lookup",
                    "service", SERVICE, "account", name], capture=True)
    elif b == "file":
        _ensure_unlocked()
        try:
            with open(os.path.join(_store_dir(), name)) as f:
                out = f.read()
        except FileNotFoundError:
            raise BrokerError(f"no secret stored for secret://{name}")
    else:
        raise _no_keyring()
    if out is None or out == "":
        raise BrokerError(f"no secret stored for secret://{name}")
    return out.rstrip("\n")


def _kr_delete(name: str) -> None:
    b = _backend()
    if b == "macos":
        _run(["security", "delete-generic-password", "-s", SERVICE, "-a", name])
    elif b == "linux":
        _run(["secret-tool", "clear", "service", SERVICE, "account", name])
    elif b == "file":
        _ensure_unlocked()
        try:
            os.unlink(os.path.join(_store_dir(), name))
        except FileNotFoundError:
            pass
    else:
        raise _no_keyring()


def _run(cmd, stdin: "str|None" = None, capture: bool = False) -> "str|None":
    """Run a keyring CLI. Scrubs the value out of any failure message."""
    try:
        proc = subprocess.run(
            cmd,
            input=(stdin.encode() if stdin is not None else None),
            stdout=subprocess.PIPE,
            stderr=subprocess.PIPE,
        )
    except FileNotFoundError:
        raise _no_keyring()
    if proc.returncode != 0:
        # stderr from keyring tools is safe (no value), but never echo our stdin.
        err = proc.stderr.decode(errors="replace").strip() or f"rc={proc.returncode}"
        raise BrokerError(f"keyring operation failed: {err}")
    return proc.stdout.decode(errors="replace") if capture else None


# --------------------------------------------------------------------------- #
# handle index (names only) — powers `list` uniformly across backends
# --------------------------------------------------------------------------- #
def _index_read() -> "list[str]":
    try:
        with open(INDEX_PATH, "r") as f:
            return [ln.strip() for ln in f if ln.strip()]
    except FileNotFoundError:
        return []


def _index_add(name: str) -> None:
    names = set(_index_read())
    names.add(name)
    _index_write(sorted(names))


def _index_remove(name: str) -> None:
    _index_write([n for n in _index_read() if n != name])


def _index_write(names: "list[str]") -> None:
    os.makedirs(AIOS_DIR, exist_ok=True)
    tmp = INDEX_PATH + ".tmp"
    with open(tmp, "w") as f:
        f.write("\n".join(names) + ("\n" if names else ""))
    os.replace(tmp, INDEX_PATH)


# --------------------------------------------------------------------------- #
# audit — metadata only, NEVER the value, NEVER blocks the action
# --------------------------------------------------------------------------- #
def _audit(handle_name: str, action: str, target: str, status: str, ms: int) -> None:
    line = {
        "ts": datetime.now(timezone.utc).strftime("%Y-%m-%dT%H:%M:%SZ"),
        "handle": f"secret://{handle_name}",
        "action": action,
        "target": target,      # coarse: recipient domain / url host — never full addr/query
        "status": status,
        "ms": ms,
    }
    try:
        os.makedirs(AIOS_DIR, exist_ok=True)
        with open(AUDIT_PATH, "a") as f:
            f.write(json.dumps(line) + "\n")
    except OSError:
        pass  # a failed audit write must never block or fail the action


def _now_ms() -> int:
    return int(datetime.now(timezone.utc).timestamp() * 1000)


# --------------------------------------------------------------------------- #
# verbs
# --------------------------------------------------------------------------- #
def cmd_set(args) -> int:
    name = parse_handle(args.handle)
    # Read the value with NO echo. The agent never sees this; the user runs it.
    import getpass
    if sys.stdin.isatty():
        value = getpass.getpass(f"Enter the secret for secret://{name} (input hidden): ")
    else:
        # non-interactive (e.g. piped) — read one line, still never echoed by us
        value = sys.stdin.readline().rstrip("\n")
    if not value:
        return _die("empty value; nothing stored")
    _kr_store(name, value)
    _index_add(name)
    del value
    if _backend() == "file":
        print(f"note: no OS keyring here — stored in {_store_dir()} "
              f"(at-rest protection is that directory's, e.g. fscrypt/LUKS).",
              file=sys.stderr)
    print(f"stored secret://{name}")
    return 0


def cmd_send_email(args) -> int:
    import smtplib
    from email.message import EmailMessage

    name = parse_handle(args.handle)
    to_domain = args.to.split("@")[-1] if "@" in args.to else "?"
    body = _read_body(args)
    t0 = _now_ms()
    try:
        value = _kr_get(name)
        msg = EmailMessage()
        msg["From"] = getattr(args, "from_")
        msg["To"] = args.to
        msg["Subject"] = args.subject or ""
        msg.set_content(body)
        user = args.user or getattr(args, "from_")
        with smtplib.SMTP(args.smtp_host, args.smtp_port, timeout=30) as s:
            s.starttls()
            s.login(user, value)
            s.send_message(msg)
        del value
    except smtplib.SMTPAuthenticationError:
        _audit(name, "send-email", to_domain, "auth-failed", _now_ms() - t0)
        return _die(f"auth rejected for secret://{name} (check the stored password)")
    except BrokerError as e:
        _audit(name, "send-email", to_domain, "error", _now_ms() - t0)
        return _die(str(e))
    except Exception as e:  # network/SMTP — scrub, never leak the value
        _audit(name, "send-email", to_domain, "error", _now_ms() - t0)
        return _die(f"send failed: {_scrub(e)}")
    _audit(name, "send-email", to_domain, "ok", _now_ms() - t0)
    print(f"sent to {args.to}")
    return 0


def cmd_fetch(args) -> int:
    from urllib.parse import urlparse

    name = parse_handle(args.handle)
    host = urlparse(args.url).netloc or "?"
    data = None
    if args.data_file:
        with open(args.data_file, "rb") as f:
            data = f.read()
    method = args.method or ("POST" if data is not None else "GET")
    t0 = _now_ms()
    try:
        value = _kr_get(name)
        headers = {}
        if args.inject == "bearer":
            headers["Authorization"] = f"Bearer {value}"
        elif args.inject.startswith("header:"):
            headers[args.inject.split(":", 1)[1]] = value
        else:
            raise BrokerError("--inject must be 'bearer' or 'header:NAME'")
        req = urllib.request.Request(args.url, data=data, headers=headers, method=method)
        with urllib.request.urlopen(req, timeout=30) as resp:
            out = resp.read()
        del value
    except BrokerError as e:
        _audit(name, "fetch", host, "error", _now_ms() - t0)
        return _die(str(e))
    except Exception as e:
        _audit(name, "fetch", host, "error", _now_ms() - t0)
        return _die(f"fetch failed: {_scrub(e)}")
    _audit(name, "fetch", host, "ok", _now_ms() - t0)
    sys.stdout.buffer.write(out)
    if not out.endswith(b"\n"):
        sys.stdout.write("\n")
    return 0


def cmd_list(args) -> int:
    if _backend() == "file":
        _ensure_unlocked()
        d = _store_dir()
        names = sorted(f for f in os.listdir(d)
                       if not f.endswith(".tmp")) if d and os.path.isdir(d) else []
    else:
        names = _index_read()
    if not names:
        print("(no secrets stored)")
        return 0
    for n in names:
        print(f"secret://{n}")
    return 0


def cmd_revoke(args) -> int:
    name = parse_handle(args.handle)
    try:
        _kr_delete(name)
    except BrokerError as e:
        return _die(str(e))
    _index_remove(name)
    print(f"revoked secret://{name}")
    return 0


def _read_body(args) -> str:
    if args.body_file:
        with open(args.body_file, "r") as f:
            return f.read()
    return args.body or ""


def _scrub(exc: Exception) -> str:
    """Best-effort: keep a raised message from ever carrying a stored value.
    We never put a value into an exception ourselves; this is defence in depth."""
    return type(exc).__name__


# --------------------------------------------------------------------------- #
# dispatch — NOTE: there is intentionally no `get`/`show`/`print`/`cat` verb.
# The only way to use a secret is to have the broker ACT with it.
# --------------------------------------------------------------------------- #
def build_parser() -> argparse.ArgumentParser:
    p = argparse.ArgumentParser(
        prog="secret",
        description="Use a stored credential by handle, without ever revealing it.",
    )
    sub = p.add_subparsers(dest="cmd", required=True)

    s = sub.add_parser("set", help="store a secret (value entered with no echo)")
    s.add_argument("handle")
    s.set_defaults(func=cmd_set)

    e = sub.add_parser("send-email", help="send email using a stored SMTP password")
    e.add_argument("handle")
    e.add_argument("--to", required=True)
    e.add_argument("--subject", default="")
    e.add_argument("--body", default=None)
    e.add_argument("--body-file", default=None)
    e.add_argument("--from", dest="from_", required=True, help="sender / SMTP username")
    e.add_argument("--user", default=None, help="SMTP username if != --from")
    e.add_argument("--smtp-host", default="smtp.gmail.com")
    e.add_argument("--smtp-port", type=int, default=587)
    e.set_defaults(func=cmd_send_email)

    f = sub.add_parser("fetch", help="authed HTTP call injecting a stored secret")
    f.add_argument("handle")
    f.add_argument("--url", required=True)
    f.add_argument("--inject", required=True, help="bearer | header:NAME")
    f.add_argument("--method", default=None, choices=[None, "GET", "POST", "PUT", "DELETE"])
    f.add_argument("--data-file", default=None)
    f.set_defaults(func=cmd_fetch)

    ls = sub.add_parser("list", help="list stored handles (names only, never values)")
    ls.set_defaults(func=cmd_list)

    r = sub.add_parser("revoke", help="delete a stored secret")
    r.add_argument("handle")
    r.set_defaults(func=cmd_revoke)
    return p


def main(argv) -> int:
    parser = build_parser()
    args = parser.parse_args(argv)
    try:
        return args.func(args)
    except BrokerError as e:
        return _die(str(e))
    except BrokenPipeError:
        return 0


if __name__ == "__main__":
    sys.exit(main(sys.argv[1:]))
